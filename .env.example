# VNForge stores API keys in the operating-system keyring when available.
# This file contains non-secret provider configuration and a secure fallback.
PROVIDER="watsonx"
SECRET_STORAGE="keyring"

WATSONX_REGION="us-south"
WATSONX_PROJECT_ID=""
WATSONX_MODEL_ID="ibm/granite-3-3-8b-instruct"
WATSONX_API_KEY=""

GEMINI_MODEL="gemini-2.0-flash"
GEMINI_API_KEY=""

OPENROUTER_MODEL=""
OPENROUTER_API_KEY=""

OPENAI_MODEL="gpt-5.1"
OPENAI_API_KEY=""

ANTHROPIC_MODEL="claude-sonnet-5"
ANTHROPIC_API_KEY=""

OPENCODE_MODEL="deepseek-v4-flash"
OPENCODE_API_KEY=""

# Optional path to renpy.sh, renpy.exe, or another Ren'Py launcher executable.
RENPY_EXECUTABLE=""
