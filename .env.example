# VNForge environment variables — written automatically by the setup window.
# Do not commit this file to source control.

# Active provider: watsonx | gemini | openrouter
PROVIDER=""

# IBM watsonx.ai (free on IBM Cloud Lite plan — https://cloud.ibm.com)
WATSONX_API_KEY=""
WATSONX_PROJECT_ID=""

# Google Gemini (free tier — https://aistudio.google.com/app/apikey)
# Free-tier model availability changes over time; check https://ai.dev/rate-limits
# Version-pinned models (e.g. gemini-2.5-flash) can be gated to existing users,
# returning 404 for newly-created API keys. The -latest alias tracks the current
# recommended version and is available to all users.
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-flash-latest"

# OpenRouter (free + paid tiers — https://openrouter.ai/keys)
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="meta-llama/llama-3.3-70b-instruct:free"
